<?xml version="1.0" encoding="utf-8"?>
<!--
    m2511: round-variant adaptive-icon. Identical layer wiring to ic_launcher.xml
    because Android applies the OEM mask on top of these layers uniformly — a
    single set of PNG assets serves both the standard and round icon slots.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
    <monochrome android:drawable="@mipmap/ic_launcher_monochrome" />
</adaptive-icon>
