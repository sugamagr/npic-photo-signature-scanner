<?xml version="1.0" encoding="utf-8"?>
<!--
    Legacy Android 11 and below backup rules. Same policy as data_extraction_rules.xml:
    exclude everything. Data is device-local by design.
-->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
</full-backup-content>
