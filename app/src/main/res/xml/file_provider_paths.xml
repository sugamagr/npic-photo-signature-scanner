<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider paths used by the export ShareSheet.
    - export/  holds transient combined/photo/signature JPEGs generated for a single share event.
    - cache/exports/  fallback for share flows that route via the cache dir.
    Both roots are inside app-internal storage; no external storage permission needed.
-->
<paths>
    <files-path name="internal_exports" path="exports/" />
    <cache-path name="cache_exports"   path="exports/" />
</paths>
