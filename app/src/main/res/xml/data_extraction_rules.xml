<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ backup/transfer policy.
    Student photos + signatures live in app-internal storage. We do NOT allow cloud backup
    or device-to-device transfer — this is per-device local data by design (§8 PRD).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
