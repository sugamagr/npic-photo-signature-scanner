<?xml version="1.0" encoding="utf-8"?>
<!--
    m2511: splash-screen vector icon (referenced by themes.xml
    windowSplashScreenAnimatedIcon). Kept as a vector so the SplashScreen Compat
    API can scale it into its 288dp icon safe zone without density-bucket assets.

    The launcher icon itself is a raster mark (gold PS-in-frame on dark navy)
    living in mipmap-*/ — that mark can't be a vector because it has 3D bevels
    and gradient shading. For the splash we render a simplified saffron
    monogram-with-photo-frame silhouette that harmonizes with the launcher
    without dragging the whole raster mark onto the ivory splash background.

    Canvas: 108x108. Safe zone: centered 66x66 (edges 21..87 both axes).
    Two saffron corner brackets forming a diagonal photo frame + a bold saffron
    'S' signature stroke in the middle. Same design language as DESIGN.md §7.10.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Top-left photo-frame corner bracket -->
    <path
        android:pathData="M 28,42 L 28,28 L 42,28"
        android:strokeColor="#F6921E"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Bottom-right photo-frame corner bracket -->
    <path
        android:pathData="M 80,66 L 80,80 L 66,80"
        android:strokeColor="#F6921E"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Signature S curve, centered inside the frame diagonal -->
    <path
        android:pathData="M 68,42 C 68,36 61,34 55,35 C 46,37 43,46 51,50 C 56,52 63,53 68,57 C 74,61 71,71 60,71 C 51,71 44,68 40,63"
        android:strokeColor="#F6921E"
        android:strokeWidth="11"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Signature flourish tail -->
    <path
        android:pathData="M 40,63 C 36,61 34,65 37,68 C 40,70 44,69 46,66"
        android:strokeColor="#F6921E"
        android:strokeWidth="4.5"
        android:strokeLineCap="round" />
</vector>
