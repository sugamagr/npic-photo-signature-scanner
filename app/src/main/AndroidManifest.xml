<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera capture: required feature; app is meaningless without a rear camera. -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- Runtime-requested permissions. -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- m2508: self-hosted updater (features/update/*). INTERNET fetches version.json
         from raw.githubusercontent.com and streams the release APK via DownloadManager.
         REQUEST_INSTALL_PACKAGES is declared here but individually granted per-source
         in Settings → Apps → Special access → Install unknown apps by the user (persists
         across our own updates). See features/update/UpdateInstaller.kt for the
         PackageInstaller Session flow. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- PRD §10: legacy write-external-storage for API ≤ 28 devices where the
         FileProvider-share flow needs an intermediate on-disk staging file that another
         app may read directly (some OEMs' share receivers ignore FileProvider Uris on
         pre-Q). API 29+ uses scoped storage exclusively. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Scoped-storage friendly: we write only to app-internal storage.
         Photo picker for gallery import is contract-based and needs no permission on API 33+.
         For API 29-32, ACCESS_MEDIA_LOCATION is only needed when reading EXIF from picked images. -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION"
        android:maxSdkVersion="32" />

    <!-- Export via ShareSheet uses a FileProvider; no storage permission required. -->

    <application
        android:name=".app.NpicApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Npic.Splash"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="34">

        <activity
            android:name=".app.MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Npic.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>
    </application>
</manifest>
